# Legacy query class upgrade path (Option B)
#
# Use this path when the project uses the older query class at
# modules/db/classes/query.php instead of modules/db/src/Query/Query.php.
#
# In this path:
# - Do NOT copy modules/db/src/Query/Traits/Metadata.php
# - Do NOT apply the Metadata trait to the query class
# - Skip the create_function() / Executor.php fix (that file does not exist)
# - StoreOrderedHook needs no rewrite if properties are already declared

# --- StoreOrderedHook ---
#
# If the hook already declares protected $conditions, $value, and $increment,
# no changes are needed. PHP 8.2 will not flag these as dynamic properties.
#
# If they are NOT declared, add them:
diff --git a/core/app/hooks/store/StoreOrderedHook.php b/core/app/hooks/store/StoreOrderedHook.php
index 08fd5fd1..fc29b9be 100644
--- a/core/app/hooks/store/StoreOrderedHook.php
+++ b/core/app/hooks/store/StoreOrderedHook.php
@@ -1,5 +1,8 @@
 class StoreOrderedHook extends QueryHook {
+  protected $conditions = false;
+  protected $value = false;
+  protected $increment = 1;
   public function __construct(DatabaseInterface $db) {
     $this->db = $db;
   }

