diff --git a/core/app/hooks/store/StoreSlugHook.php b/core/app/hooks/store/StoreSlugHook.php
index 93dd8d52..57c501ef 100644
--- a/core/app/hooks/store/StoreSlugHook.php
+++ b/core/app/hooks/store/StoreSlugHook.php
@@ -42,7 +42,11 @@ class StoreSlugHook extends QueryHook {
     if (!empty($this->models->get($query->model)->hooks[$column]["unique"])) {
       $parts = explode(" ", $this->models->get($query->model)->hooks[$column]["unique"]);
-      foreach ($parts as $c) if (!empty($c)) $exists->condition($c, $query->fields[$c]);
+      foreach ($parts as $c) {
+        if (!empty($c) && isset($query->fields[$c])) {
